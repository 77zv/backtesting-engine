# Copy to .env and fill in. Get a free practice token at https://www.oanda.com/demo-account/tpa/personal_token
OANDA_API_TOKEN=your-token-here
OANDA_ACCOUNT_ID=000-000-0000000-000
# practice (demo) or live
OANDA_ENV=practice
# Optional: where to cache downloaded candles (defaults to ./data)
BT_DATA_DIR=data
